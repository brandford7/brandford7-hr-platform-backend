# --- Server Configuration ---
PORT=5000
NODE_ENV=development

# --- Database (Prisma) ---
# Replace with your actual connection string in .env
# Example: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/hr_system_db?schema=public"

# --- Authentication (JWT) ---
# Use a long, random string for production
JWT_SECRET=your_super_secret_random_string_here
JWT_EXPIRES_IN=1d

# --- CORS Settings ---
# The URL of your React frontend
CLIENT_URL=http://localhost:3000